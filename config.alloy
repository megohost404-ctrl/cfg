// ============================================
// USB Logs (Подключение внешних устройств) - ИСПРАВЛЕННАЯ ВЕРСИЯ
// ============================================
loki.source.windowsevent "usb" {
    eventlog_name          = "Microsoft-Windows-DriverFrameworks-UserMode/Operational"
    xpath_query            = "*"
    bookmark_path          = "./bookmark-usb.xml"
    poll_interval          = "0s"
    use_incoming_timestamp = true
    forward_to             = [loki.process.usb.receiver]
    labels                 = {
        job      = "windows_usb",
        host     = constants.hostname,
    }
}

loki.process "usb" {
    forward_to = [loki.write.loki.receiver]

    stage.json {
        expressions = {
            event_id    = "event_id",
            computer    = "computer",
            timeCreated = "timeCreated",
            event_data  = "event_data",
            message     = "message",
        }
    }

    // Извлекаем серийный номер из InstanceId
    stage.regex {
        source     = "event_data"
        expression = "#(?P<usb_serial>[^#]+)"
    }

    // Извлекаем тип устройства
    stage.regex {
        source     = "event_data"
        expression = "VID_(?P<usb_vid>[^&]+)&PID_(?P<usb_pid>[^#]+)"
    }

    stage.labels {
        values = {
            event_id    = "",
            usb_serial  = "",
            usb_vid     = "",
            usb_pid     = "",
            computer    = "",
        }
    }

    stage.timestamp {
        source = "timeCreated"
        format = "RFC3339"
    }
}

// ============================================
// System Logs (Критические ошибки системы)
// ============================================
loki.source.windowsevent "system" {
    eventlog_name          = "System"
    xpath_query            = "*"
    bookmark_path          = "./bookmark-system.xml"
    poll_interval          = "0s"
    use_incoming_timestamp = true
    forward_to             = [loki.process.system.receiver]
    labels                 = {
        job      = "windows_system",
        host     = constants.hostname,
    }
}

loki.process "system" {
    forward_to = [loki.write.loki.receiver]

    stage.json {
        expressions = {
            event_id    = "event_id",
            computer    = "computer",
            timeCreated = "timeCreated",
            level       = "level",
            levelText   = "levelText",
            message     = "message",
            source      = "source",
        }
    }

    stage.labels {
        values = {
            event_id    = "",
            computer    = "",
            level       = "",
            levelText   = "",
            source      = "",
        }
    }

    stage.timestamp {
        source = "timeCreated"
        format = "RFC3339"
    }
}

// ============================================
// Security Logs (Входы/Выходы)
// ============================================
loki.source.windowsevent "security" {
    eventlog_name = "Security"
    xpath_query   = "*[System[(EventID=4624 or EventID=4634 or EventID=4647)]]"
    forward_to    = [loki.process.security.receiver]
    labels        = { job = "windows_security" }
}

loki.process "security" {
    forward_to = [loki.write.loki.receiver]
    
    stage.json {
        expressions = {
            event_id    = "event_id",
            computer    = "computer",
            timeCreated = "timeCreated",
            event_data  = "event_data",
        }
    }

    stage.replace {
        source     = "event_data"
        expression = "\\\\u003c"
        replace    = "<"
    }
    stage.replace {
        source     = "event_data"
        expression = "\\\\u003e"
        replace    = ">"
    }

    stage.regex {
        source     = "event_data"
        expression = "<Data Name='TargetUserName'>(?P<username>[^<]+)</Data>"
    }
    stage.regex {
        source     = "event_data"
        expression = "<Data Name='TargetDomainName'>(?P<domain>[^<]+)</Data>"
    }
    stage.regex {
        source     = "event_data"
        expression = "<Data Name='LogonType'>(?P<logon_type>[^<]+)</Data>"
    }

    stage.labels {
        values = {
            event_id    = "",
            computer    = "",
            username    = "",
            domain      = "",
            logon_type  = "",
        }
    }

    stage.timestamp {
        source = "timeCreated"
        format = "RFC3339"
    }
}

