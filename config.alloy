// ============================================
// Sysmon Logs (Детальная информация о процессах)
// ============================================
loki.source.windowsevent "sysmon" {
    eventlog_name          = "Microsoft-Windows-Sysmon/Operational"
    xpath_query            = "*"
    bookmark_path          = "./bookmark-sysmon.xml"
    poll_interval          = "0s"
    use_incoming_timestamp = true
    forward_to             = [loki.process.sysmon.receiver]
    labels                 = {
        job      = "windows_sysmon",
        host     = constants.hostname,
    }
}

loki.process "sysmon" {
    forward_to = [loki.write.loki.receiver]

    stage.json {
        expressions = {
            event_id    = "event_id",
            computer    = "computer",
            timeCreated = "timeCreated",
            event_data  = "event_data",
            message     = "message",
        }
    }

    stage.regex {
        source     = "event_data"
        expression = "<Data Name='Image'>(?P<image>[^<]+)</Data>"
    }
    stage.regex {
        source     = "event_data"
        expression = "<Data Name='CommandLine'>(?P<command_line>[^<]+)</Data>"
    }
    stage.regex {
        source     = "event_data"
        expression = "<Data Name='ProcessGuid'>(?P<process_guid>[^<]+)</Data>"
    }
    stage.regex {
        source     = "event_data"
        expression = "<Data Name='ProcessId'>(?P<process_id>[^<]+)</Data>"
    }
    stage.regex {
        source     = "event_data"
        expression = "<Data Name='User'>(?P<user>[^<]+)</Data>"
    }

    stage.labels {
        values = {
            event_id     = "",
            image        = "",
            command_line = "",
            user         = "",
        }
    }

    stage.timestamp {
        source = "timeCreated"
        format = "RFC3339"
    }
}

// ============================================
// Loki Write
// ============================================
loki.write "loki" {
    endpoint {
        url = "http://192.168.100.209:3116/loki/api/v1/push"
    }
}
